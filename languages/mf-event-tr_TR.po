msgstr "— Ay —"

#: mf-event.php:190 mf-event.php:202
msgid "Day"
msgstr "Gün"

#: mf-event.php:194
msgid "End date"
msgstr "Bitiş tarihi"

#: mf-event.php:194
msgid "Only for multi-day events (e.g. a school break). Leave empty for single-day events."
msgstr "Yalnızca birden çok gün süren etkinlikler içindir (ör. okul ara tatili). Tek günlük etkinliklerde boş bırakın."

#: mf-event.php:206
msgid "Year"
msgstr "Yıl"

#: mf-event.php:206
msgid "<strong>Leave empty</strong> for dates that repeat the same day every year (most Gregorian dates).<br><strong>Set a year</strong> for dates that shift each year — Hijri / religious days like Ramadan, Eid, Mawlid. When that day passes it disappears automatically; add the next year's entry to keep it showing."
msgstr "Her yıl aynı güne denk gelen tarihler için (çoğu Miladi tarih) <strong>boş bırakın</strong>.<br>Her yıl kayan tarihler için <strong>bir yıl girin</strong> — Ramazan, Bayram, Mevlid gibi Hicri / dinî günler. O gün geçtiğinde otomatik olarak kaybolur; göstermeye devam etmek için bir sonraki yılın kaydını ekleyin."

#: mf-event.php:207
msgid "e.g. 2027"
msgstr "ör. 2027"

#: mf-event.php:210 mf-event.php:373
msgid "Type"
msgstr "Tür"

#: mf-event.php:210
msgid "Controls the colour accent of the card. Manage types under <em>MF Events → Settings</em>."
msgstr "Kartın vurgu rengini belirler. Türleri <em>MF Etkinlikler → Ayarlar</em> altından yönetin."

#: mf-event.php:220
msgid "The event name is the post title above. Order is handled automatically by date."
msgstr "Etkinlik adı yukarıdaki yazı başlığıdır. Sıralama tarihe göre otomatik yapılır."

#: mf-event.php:221
msgid "Add longer details in the main content editor above — if filled, the event opens in a pop-up on the front end. Set a Featured image to show it as the event poster."
msgstr "Daha uzun ayrıntıları yukarıdaki ana içerik editörüne ekleyin — doldurulursa etkinlik ön yüzde bir açılır pencerede açılır. Etkinlik afişi olarak göstermek için bir Öne Çıkan Görsel ayarlayın."

#: mf-event.php:233
msgid "Pages"
msgstr "Sayfalar"

#: mf-event.php:236
msgid "Posts"
msgstr "Yazılar"

#: mf-event.php:240
msgid "— Manual link (use URL field) —"
msgstr "— Manuel bağlantı (URL alanını kullanın) —"

#: mf-event.php:244
#, php-format
msgid "#%d (no title)"
msgstr "#%d (başlıksız)"

#: mf-event.php:268
msgid "Link this event to related content. Pick a page/post from your site (its link stays correct even if the URL changes), or enter a custom URL. Links appear inside the event pop-up."
msgstr "Bu etkinliği ilgili içeriğe bağlayın. Sitenizden bir sayfa/yazı seçin (URL değişse bile bağlantısı doğru kalır) veya özel bir URL girin. Bağlantılar etkinlik açılır penceresinde görünür."

#: mf-event.php:271
msgid "Site content"
msgstr "Site içeriği"

#: mf-event.php:272
msgid "Custom URL"
msgstr "Özel URL"

#: mf-event.php:273
msgid "Label (optional)"
msgstr "Etiket (isteğe bağlı)"

#: mf-event.php:274 mf-event.php:571
msgid "Delete"
msgstr "Sil"

#: mf-event.php:291
msgid "+ Add link"
msgstr "+ Bağlantı ekle"

#: mf-event.php:372
msgid "Date"
msgstr "Tarih"

#: mf-event.php:396
msgid "(yearly)"
msgstr "(her yıl)"

#: mf-event.php:424
msgid "MF Event Settings"
msgstr "MF Event Ayarları"

#: mf-event.php:425
msgid "Settings"
msgstr "Ayarlar"

#: mf-event.php:494
msgid "MF Event — Settings"
msgstr "MF Event — Ayarlar"

#: mf-event.php:496
msgid "Settings saved."
msgstr "Ayarlar kaydedildi."

#: mf-event.php:499
msgid "Shortcode"
msgstr "Kısa kod"

#: mf-event.php:500
msgid "Place this shortcode in any page, post, or page-builder text/HTML element:"
msgstr "Bu kısa kodu herhangi bir sayfaya, yazıya veya sayfa oluşturucu metin/HTML öğesine yerleştirin:"

#: mf-event.php:503
#, php-format
msgid "(the alias %s works too)"
msgstr "(%s takma adı da çalışır)"

#: mf-event.php:506
msgid "Parameters"
msgstr "Parametreler"

#: mf-event.php:509
msgid "Parameter"
msgstr "Parametre"

#: mf-event.php:510
msgid "Default"
msgstr "Varsayılan"

#: mf-event.php:511
msgid "What it does"
msgstr "Ne işe yarar"

#: mf-event.php:512
msgid "Example"
msgstr "Örnek"

#: mf-event.php:515
msgid "How many months ahead to show. Events further in the future than this are hidden (this is also what keeps next year’s religious dates from appearing too early)."
msgstr "Kaç ay ilerisinin gösterileceği. Bundan daha ileri tarihli etkinlikler gizlenir (bu, gelecek yılın dinî günlerinin çok erken görünmesini de engeller)."

#: mf-event.php:516
msgid "Maximum number of upcoming items to list. <code>0</code> means no limit."
msgstr "Listelenecek en fazla yaklaşan öğe sayısı. <code>0</code> sınır yok demektir."

#: mf-event.php:517
msgid "Show the highlighted “Today” boxes at the top for events happening today. Set to <code>no</code> to hide that section."
msgstr "Bugün gerçekleşen etkinlikler için üstte vurgulanan “Bugün” kutularını gösterir. Bu bölümü gizlemek için <code>no</code> yapın."

#: mf-event.php:518
msgid "(empty)"
msgstr "(boş)"

#: mf-event.php:518
msgid "Optional heading shown above the list."
msgstr "Listenin üzerinde gösterilen isteğe bağlı başlık."

#: mf-event.php:519
msgid "(all)"
msgstr "(tümü)"

#: mf-event.php:519
msgid "Show only one type, using its <em>slug</em> (see the Types table below). Leave empty to show all."
msgstr "Yalnızca tek bir türü, <em>slug</em>’ını kullanarak gösterir (aşağıdaki Türler tablosuna bakın). Tümünü göstermek için boş bırakın."

#: mf-event.php:520
msgid "(setting)"
msgstr "(ayar)"

#: mf-event.php:520
msgid "Override the display style for this one shortcode: <code>classic</code>, <code>cards</code>, <code>grid</code>, <code>editorial</code> or <code>timeline</code>. Leave empty to use the default chosen below."
msgstr "Yalnızca bu kısa kod için görünüm stilini değiştirir: <code>classic</code>, <code>cards</code>, <code>grid</code>, <code>editorial</code> veya <code>timeline</code>. Aşağıda seçilen varsayılanı kullanmak için boş bırakın."

#: mf-event.php:523
msgid "You can combine parameters, e.g. <code>[mf_event title=\"This Year\" months=\"12\" limit=\"10\"]</code>."
msgstr "Parametreleri birleştirebilirsiniz, ör. <code>[mf_event title=\"This Year\" months=\"12\" limit=\"10\"]</code>."

#: mf-event.php:525
msgid "How dates work"
msgstr "Tarihler nasıl çalışır"

#: mf-event.php:527
msgid "<strong>No year</strong> on an event → it repeats the same day every year (use for fixed Gregorian dates and school events)."
msgstr "Bir etkinlikte <strong>yıl yok</strong> → her yıl aynı gün tekrarlanır (sabit Miladi tarihler ve okul etkinlikleri için kullanın)."

#: mf-event.php:528
msgid "<strong>A year set</strong> on an event → a one-off date for that specific year (use for Hijri / religious days that shift). When the day passes it drops off automatically; add next year’s entry to keep it visible."
msgstr "Bir etkinlikte <strong>yıl belirtildi</strong> → o yıla özel tek seferlik tarih (kayan Hicri / dinî günler için kullanın). Gün geçtiğinde otomatik olarak kaybolur; görünür kalması için sonraki yılın kaydını ekleyin."

#: mf-event.php:529
msgid "The list is ordered relative to <strong>today</strong>. Items happening today appear at the top in their own boxes. Make sure your <em>Settings → General → Timezone</em> in WordPress is correct, since “today” uses the site timezone."
msgstr "Liste <strong>bugüne</strong> göre sıralanır. Bugün gerçekleşen öğeler kendi kutularında en üstte görünür. “Bugün” site saat dilimini kullandığından, WordPress’teki <em>Ayarlar → Genel → Saat Dilimi</em> ayarınızın doğru olduğundan emin olun."

#: mf-event.php:530
msgid "Multi-day events use the optional <strong>End date</strong> (year-spanning ranges like Dec 25 – Jan 3 are supported)."
msgstr "Birden çok gün süren etkinlikler isteğe bağlı <strong>Bitiş tarihi</strong>ni kullanır (25 Ara – 3 Oca gibi yılı aşan aralıklar desteklenir)."

#: mf-event.php:538
msgid "Display style"
msgstr "Görünüm stili"

#: mf-event.php:539
msgid "Choose how the event list looks on the front end. A single shortcode can override this with the style=\"…\" parameter."
msgstr "Etkinlik listesinin ön yüzde nasıl görüneceğini seçin. Tek bir kısa kod, style=\"…\" parametresiyle bunu geçersiz kılabilir."

#: mf-event.php:542
msgid "Classic"
msgstr "Klasik"

#: mf-event.php:542
msgid "The original look: full-width rows with a neutral surface and a thin coloured accent stripe on the left."
msgstr "Orijinal görünüm: nötr zeminli tam genişlikte satırlar ve solda ince renkli vurgu şeridi."

#: mf-event.php:543
msgid "Cards"
msgstr "Kartlar"

#: mf-event.php:543
msgid "Coloured cards with a filled date tile and a soft type-colour wash. Warm and inviting."
msgstr "Dolu tarih kutusu ve türün renginin hafif tonuyla zeminlenmiş renkli kartlar. Sıcak ve davetkâr."

#: mf-event.php:544
msgid "Grid"
msgstr "Izgara"

#: mf-event.php:544
msgid "Soft pastel boxes, three per row, grouped by month, washed in the type colour with the date as a corner badge."
msgstr "Yumuşak pastel kutular, satırda üç tane, aylara göre gruplanmış, türün rengiyle hafifçe tonlanmış ve tarih köşede rozet olarak."

#: mf-event.php:545
msgid "Editorial"
msgstr "Editöryel"

#: mf-event.php:545
msgid "Calm hairline rows grouped by month, with the type shown as a small label. Clean and premium."
msgstr "Aylara göre gruplanmış, ince çizgili sakin satırlar; tür küçük bir etiket olarak gösterilir. Temiz ve şık."

#: mf-event.php:546
msgid "Timeline"
msgstr "Zaman tüneli"

#: mf-event.php:546
msgid "A vertical line with a coloured dot per event, grouped by month. Calendar feel."
msgstr "Her etkinlik için renkli bir nokta içeren, aylara göre gruplanmış dikey çizgi. Takvim hissi."

#: mf-event.php:563
msgid "Event Types"
msgstr "Etkinlik Türleri"

#: mf-event.php:564
msgid "Each type has a colour used as the card’s accent. Add your own, rename them, or change colours. The <strong>slug</strong> is the value used in the <code>type=\"…\"</code> shortcode parameter; it’s generated automatically from the name for new types and can’t be edited afterwards (so existing events keep working)."
msgstr "Her türün, kartın vurgusu olarak kullanılan bir rengi vardır. Kendinizinkini ekleyin, yeniden adlandırın veya renkleri değiştirin. <strong>Slug</strong>, <code>type=\"…\"</code> kısa kod parametresinde kullanılan değerdir; yeni türler için addan otomatik üretilir ve sonradan düzenlenemez (böylece mevcut etkinlikler çalışmaya devam eder)."

#: mf-event.php:568
msgid "Name"
msgstr "Ad"

#: mf-event.php:569
msgid "Slug"
msgstr "Slug"

#: mf-event.php:570
msgid "Colour"
msgstr "Renk"

#: mf-event.php:585
msgid "+ Add type"
msgstr "+ Tür ekle"

#: mf-event.php:588
msgid "Save settings"
msgstr "Ayarları kaydet"

#: mf-event.php:590
msgid "Reset all types to the defaults? Custom types will be removed."
msgstr "Tüm türler varsayılanlara sıfırlansın mı? Özel türler kaldırılacaktır."

#: mf-event.php:590
msgid "Reset to defaults"
msgstr "Varsayılanlara sıfırla"

#: mf-event.php:600
msgid "e.g. Exam"
msgstr "ör. Sınav"

#: mf-event.php:601
msgid "auto from name"
msgstr "addan otomatik"

#: mf-event.php:759
msgid "Close"
msgstr "Kapat"

#: mf-event.php:760 mf-event.php:977
msgid "Related links"
msgstr "İlişkili bağlantılar"

#: mf-event.php:847 mf-event.php:957
msgid "Today"
msgstr "Bugün"

#: mf-event.php:868
msgid "No upcoming events."
msgstr "Yaklaşan etkinlik yok."

#: mf-event.php:964
msgid "Details"
msgstr "Ayrıntılar"

#: mf-event.php:1009
msgid "No events yet."
msgstr "Henüz etkinlik yok."

#: mf-event.php:1011
msgid "Load sample events"
msgstr "Örnek etkinlikleri yükle"

#: mf-event.php:1012
msgid "to start from a ready-made academic-calendar set you can edit, or add your own."
msgstr "düzenleyebileceğiniz hazır bir akademik takvim setiyle başlamak için ya da kendinizinkini ekleyin."

#: mf-event.php:1111
#, php-format
msgid "Found %s event from the previous isabet-events plugin."
msgid_plural "Found %s events from the previous isabet-events plugin."
msgstr[0] "Önceki isabet-events eklentisinden %s etkinlik bulundu."
msgstr[1] "Önceki isabet-events eklentisinden %s etkinlik bulundu."

#: mf-event.php:1115
msgid "Import them into MF Event"
msgstr "Bunları MF Event’e aktar"

#: mf-event.php:1116
msgid "— copies titles, dates and types. Runs once; no duplicates."
msgstr "— başlıkları, tarihleri ve türleri kopyalar. Bir kez çalışır; yinelenmez."

